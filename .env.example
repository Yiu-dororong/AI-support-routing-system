# Hugging Face token for faster downloads and avoiding rate limits
# HF_TOKEN="hf_..."

# Langfuse API credentials for optional execution tracing
# Obtain these from your Langfuse project settings dashboard (https://cloud.langfuse.com)
# LANGFUSE_PUBLIC_KEY="pk-lf-..."
# LANGFUSE_SECRET_KEY="sk-lf-..."
# LANGFUSE_HOST="https://cloud.langfuse.com" # Change to self-hosted URL if not using Langfuse Cloud

# OpenAI API key for RAGAS LLM-judged evaluation metrics (optional)
# Enables Faithfulness, Answer Relevance, Context Recall, and Context Precision scoring.
# A high-capability model (gpt-4o or equivalent) is required for reliable results.
# Without this key, RAGAS evaluation is disabled and only Hit@K runs.
# OPENAI_API_KEY="sk-..."

# Override the LLM judge model used by RAGAS (optional, default: gpt-4o)
# RAGAS_LLM_MODEL="gpt-4o"
# RAGAS_LLM_API_KEY=""
# RAGAS_LLM_BASE_URL=""
# RAGAS_BATCH_SIZE="5"
# RAGAS_BATCH_SLEEP="1"

# --- Notion API Configuration ---                                                                                                                                                                                                                                                                                                                          
# The official Notion server reads this variable to communicate with Notion                                                                                                                                                                                                                                                                                 
# NOTION_TOKEN="ntn_..."                                                                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                                                                                                                            
# --- PostgreSQL Connection Configuration (Optional - defaults to localhost/postgres/postgres) ---                                                                                                                                                                                                                                                          
# Our custom PostgreSQL server reads these variables to execute queries                                                                                                                                                                                                                                                                                     
# DB_HOST="127.0.0.1"                                                                                                                                                                                                                                                                                                                                         
# DB_PORT="5432"                                                                                                                                                                                                                                                                                                                                              
# DB_NAME="postgres"                                                                                                                                                                                                                                                                                                                                          
# DB_USER="postgres"                                                                                                                                                                                                                                                                                                                                          
# DB_PASSWORD="postgres"    